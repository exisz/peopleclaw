# peopleclaw-vercel broker server
# Never commit real values in public/shared repos.
VERCEL_TOKEN=vercel_pat_server_side_only
PCV_ADMIN_SECRET=change-me-long-random-admin-secret
PCV_PUBLIC_URL=https://vercel-broker.example.com
PCV_DATA_DIR=/data
PCV_TOKEN_STORE=/data/tokens.json
PCV_AUDIT_LOG=/data/audit.jsonl
PCV_HOST=0.0.0.0
PCV_PORT=8787
# Optional default team scoping appended to upstream Vercel requests when absent.
# VERCEL_TEAM_ID=team_xxx
