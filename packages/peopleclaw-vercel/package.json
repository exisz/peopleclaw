{
  "name": "@peopleclaw/vercel-broker",
  "version": "0.1.0",
  "private": true,
  "description": "PeopleClaw Vercel broker — scoped customer tokens, deny-by-default allowlist, headless persistent proxy server, plus standalone pcv CLI",
  "type": "module",
  "bin": {
    "pcv": "./dist/cli.js",
    "peopleclaw-vercel": "./dist/cli.js",
    "pcv-server": "./dist/server.js"
  },
  "files": ["dist", "templates", "docker", "README.md", ".env.example"],
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "start:server": "node dist/server.js",
    "dev:server": "tsx src/server/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "peopleclaw": {
    "kind": "vercel-broker",
    "ticket": "PLANET-2761"
  }
}
