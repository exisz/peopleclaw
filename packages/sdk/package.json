{
  "name": "@peopleclaw/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./sse": {
      "types": "./dist/sse.d.ts",
      "import": "./dist/sse.mjs",
      "require": "./dist/sse.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.cjs"
    },
    "./app-artifact": {
      "types": "./dist/app-artifact.d.ts",
      "import": "./dist/app-artifact.mjs",
      "require": "./dist/app-artifact.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/app-artifact.test.ts"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "tsx": "^4.19.0"
  }
}
