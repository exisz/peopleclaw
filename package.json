{
  "name": "peopleclaw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev:landing": "pnpm --filter landing dev",
    "dev:admin": "pnpm --filter @peopleclaw/admin dev",
    "build:landing": "pnpm --filter landing build",
    "build:admin": "pnpm --filter @peopleclaw/admin build",
    "db:generate": "pnpm --filter @peopleclaw/admin exec prisma generate",
    "db:push-remote": "pnpm --filter @peopleclaw/admin exec node scripts/db-push-remote.mjs",
    "test:e2e": "pnpm --filter @peopleclaw/admin e2e",
    "test:e2e:ui": "pnpm --filter @peopleclaw/admin e2e:ui",
    "test:e2e:headed": "pnpm --filter @peopleclaw/admin e2e:headed",
    "test:e2e:prod": "PLAYWRIGHT_BASE_URL=https://app.peopleclaw.rollersoft.com.au pnpm --filter @peopleclaw/admin e2e"
  }
}
