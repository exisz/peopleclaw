generator client {
  provider = "prisma-client-js"
  output   = "../src/server/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("LOCAL_DATABASE_URL")
}

model User {
  id               Int      @id @default(autoincrement())
  logtoId          String   @unique
  email            String?
  visits           Int      @default(0)
  credits          Int      @default(10) // legacy (per-user); tenant credits supersede
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  cases            Case[]
  usageLogs        UsageLog[]
  tenants          TenantUser[]
}

model Tenant {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  plan             String       @default("free") // free|starter|pro|business
  credits          Int          @default(20)
  stripeCustomerId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  members          TenantUser[]
  workflows        Workflow[]
  cases            Case[]
  connections      Connection[]
  usageLogs        UsageLog[]
}

model TenantUser {
  id        Int      @id @default(autoincrement())
  tenantId  String
  userId    Int
  role      String   @default("member") // owner|admin|member
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  @@unique([tenantId, userId])
}

model Connection {
  id        String   @id @default(cuid())
  tenantId  String
  type      String // "shopify" | "notion" | "stripe" | etc
  config    String   @default("{}") // JSON string (sqlite has no native Json)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  @@unique([tenantId, type])
}

model Workflow {
  id         String   @id
  tenantId   String?
  name       String
  category   String?
  definition String // JSON serialized {nodes, edges}
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  cases      Case[]
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
}

model Case {
  id            String     @id @default(cuid())
  tenantId      String?
  workflowId    String
  workflow      Workflow   @relation(fields: [workflowId], references: [id])
  ownerId       Int
  owner         User       @relation(fields: [ownerId], references: [id])
  title         String
  status        String     @default("running") // running|waiting_human|done|failed|cancelled
  currentStepId String?
  payload       String     @default("{}") // JSON
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  steps         CaseStep[]
  tenant        Tenant?    @relation(fields: [tenantId], references: [id])
}

model CaseStep {
  id          String    @id @default(cuid())
  caseId      String
  case        Case      @relation(fields: [caseId], references: [id])
  stepId      String
  stepType    String
  kind        String // auto|human
  status      String    @default("pending")
  input       String    @default("{}") // JSON
  output      String    @default("{}") // JSON
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

model UsageLog {
  id           Int      @id @default(autoincrement())
  tenantId     String?
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  action       String
  creditsUsed  Int      @default(0)
  creditsAdded Int      @default(0)
  packId       String?
  amountPaid   Int?
  metadata     String   @default("{}") // JSON
  createdAt    DateTime @default(now())
}
