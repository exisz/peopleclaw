generator client {
  provider = "prisma-client-js"
  output   = "../src/server/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("LOCAL_DATABASE_URL")
}

model User {
  id               Int      @id @default(autoincrement())
  logtoId          String   @unique
  email            String?
  visits           Int      @default(0)
  credits          Int      @default(10)
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  usageLogs        UsageLog[]
  tenants          TenantUser[]
}

model Tenant {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  plan             String       @default("free")
  credits          Int          @default(20)
  stripeCustomerId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  members          TenantUser[]
  connections      Connection[]
  usageLogs        UsageLog[]
  apps             App[]
}

model TenantUser {
  id        Int      @id @default(autoincrement())
  tenantId  String
  userId    Int
  role      String   @default("member")
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  @@unique([tenantId, userId])
}

model Connection {
  id        String   @id @default(cuid())
  tenantId  String
  type      String
  config    String   @default("{}")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  @@unique([tenantId, type])
}

enum ComponentType {
  FRONTEND
  BACKEND
  FULLSTACK
}

enum ComponentRuntime {
  PEOPLECLAW_CLOUD
  USER_BYO_NODE
  EDGE
}

enum ConnectionType {
  TRIGGER
  DATA_FLOW
}

model App {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  description String?
  secrets     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  components  Component[]
  connections ComponentConnection[]
  @@index([tenantId])
}

model Component {
  id           String           @id @default(cuid())
  appId        String
  type         ComponentType
  name         String
  runtime      ComponentRuntime @default(PEOPLECLAW_CLOUD)
  code         String           @default("")
  inputSchema  String?
  outputSchema String?
  probes       String?
  canvasX      Int              @default(0)
  canvasY      Int              @default(0)
  icon         String?
  compiledArtifacts String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  app          App              @relation(fields: [appId], references: [id], onDelete: Cascade)
  connectionsFrom ComponentConnection[] @relation("FromComponent")
  connectionsTo   ComponentConnection[] @relation("ToComponent")
  @@index([appId])
}

model ComponentConnection {
  id              String         @id @default(cuid())
  appId           String
  fromComponentId String
  toComponentId   String
  type            ConnectionType
  createdAt       DateTime       @default(now())
  app             App            @relation(fields: [appId], references: [id], onDelete: Cascade)
  fromComponent   Component      @relation("FromComponent", fields: [fromComponentId], references: [id], onDelete: Cascade)
  toComponent     Component      @relation("ToComponent", fields: [toComponentId], references: [id], onDelete: Cascade)
  @@index([appId])
  @@unique([fromComponentId, toComponentId, type])
}

model UsageLog {
  id           Int      @id @default(autoincrement())
  tenantId     String?
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  action       String
  creditsUsed  Int      @default(0)
  creditsAdded Int      @default(0)
  packId       String?
  amountPaid   Int?
  metadata     String   @default("{}")
  createdAt    DateTime @default(now())
}
