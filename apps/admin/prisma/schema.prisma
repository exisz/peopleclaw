generator client {
  provider = "prisma-client-js"
  output   = "../src/server/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("LOCAL_DATABASE_URL")
}

model User {
  id                       Int                @id @default(autoincrement())
  logtoId                  String             @unique
  email                    String?
  visits                   Int                @default(0)
  credits                  Int                @default(10)
  stripeCustomerId         String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  usageLogs                UsageLog[]
  tenants                  TenantUser[]
  createdExternalAgentKeys ExternalAgentKey[]
}

model Tenant {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  plan              String             @default("free")
  credits           Int                @default(20)
  stripeCustomerId  String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  members           TenantUser[]
  tenantIntegrations Connection[]
  usageLogs         UsageLog[]
  apps              App[]
  externalAgentKeys ExternalAgentKey[]
}

model TenantUser {
  id        Int      @id @default(autoincrement())
  tenantId  String
  userId    Int
  role      String   @default("member")
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
}

model Connection {
  id        String   @id @default(cuid())
  tenantId  String
  type      String
  config    String   @default("{}")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, type])
}

enum ComponentType {
  FRONTEND
  BACKEND
  FULLSTACK
}

enum ComponentRuntime {
  PEOPLECLAW_CLOUD
  USER_BYO_NODE
  EDGE
}


model App {
  id                String                @id @default(cuid())
  tenantId          String
  name              String
  description       String?
  secrets           String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  tenant            Tenant                @relation(fields: [tenantId], references: [id])
  components        Component[]
  scheduledTasks    ScheduledTask[]
  externalAgentKeys ExternalAgentKey[]

  @@index([tenantId])
}

/// PLANET-1937 / PLANET-1941 — user-owned external coding-agent API keys.
/// Stores only hashed one-time tokens. Keys are tenant-scoped and optionally
/// app-scoped; external agents must go through scoped code-function APIs only.
model ExternalAgentKey {
  id              String    @id @default(cuid())
  tenantId        String
  appId           String?
  name            String
  prefix          String    @unique
  tokenHash       String    @unique
  scopes          String    @default("[]")
  createdByUserId Int?
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app             App?      @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdBy       User?     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([appId])
  @@index([tenantId, revokedAt])
}

model Component {
  id                String                @id @default(cuid())
  appId             String
  type              ComponentType
  name              String
  runtime           ComponentRuntime      @default(PEOPLECLAW_CLOUD)
  code              String                @default("")
  inputSchema       String?
  outputSchema      String?
  icon              String?
  compiledArtifacts String?
  isExported        Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  app               App                   @relation(fields: [appId], references: [id], onDelete: Cascade)
  scheduledTasks    ScheduledTask[]

  @@index([appId])
}


model ScheduledTask {
  id          String         @id @default(cuid())
  appId       String
  componentId String
  cron        String
  enabled     Boolean        @default(true)
  lastRunAt   DateTime?
  lastStatus  String?
  lastError   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  app         App            @relation(fields: [appId], references: [id], onDelete: Cascade)
  component   Component      @relation(fields: [componentId], references: [id], onDelete: Cascade)
  runs        ScheduledRun[]

  @@index([appId])
  @@index([componentId])
}

model ScheduledRun {
  id              String        @id @default(cuid())
  scheduledTaskId String
  startedAt       DateTime      @default(now())
  finishedAt      DateTime?
  status          String
  output          String?
  error           String?
  task            ScheduledTask @relation(fields: [scheduledTaskId], references: [id], onDelete: Cascade)

  @@index([scheduledTaskId])
}

/// PLANET-1577 — generic durable per-App key/value store backing ctx.appStore.
/// Scoped by (tenantId, appId, table). Payload is JSON-encoded record body.
/// Core stays business-agnostic: any App (CRM, todos, polls, ...) shares the
/// same shape; no domain columns leak into platform schema.
model AppStoreRecord {
  id        String   @id @default(cuid())
  tenantId  String
  appId     String
  table     String
  payload   String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appId, table])
  @@index([tenantId, appId, table])
}

model UsageLog {
  id           Int      @id @default(autoincrement())
  tenantId     String?
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  action       String
  creditsUsed  Int      @default(0)
  creditsAdded Int      @default(0)
  packId       String?
  amountPaid   Int?
  metadata     String   @default("{}")
  createdAt    DateTime @default(now())
}
