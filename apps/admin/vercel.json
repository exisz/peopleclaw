{
  "framework": null,
  "ignoreCommand": "! git diff HEAD~1 --name-only | grep -qE '^(apps/admin/|package\\.json|pnpm-lock\\.yaml|pnpm-workspace\\.yaml)'",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile=false",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/internal/refresh-shopify-tokens",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/internal/run-scheduled",
      "schedule": "*/5 * * * *"
    }
  ]
}
