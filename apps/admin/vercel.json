{
  "framework": null,
  "ignoreCommand": "! git diff HEAD~1 --name-only | grep -q '^apps/admin/'",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile=false",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/internal/refresh-shopify-tokens",
      "schedule": "0 */12 * * *"
    }
  ]
}
