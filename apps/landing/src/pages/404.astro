---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, t } from '../i18n/utils';
const lang = getLang(Astro.url);
const homeHref = lang === 'zh' ? '/zh/' : '/';
---
<BaseLayout title={t(lang, 'notFound.title')}>
  <div class="hero min-h-[40vh]">
    <div class="hero-content text-center">
      <div>
        <h1 class="text-6xl font-bold">{t(lang, 'notFound.heading')}</h1>
        <p class="py-4 opacity-70">{t(lang, 'notFound.message')}</p>
        <a href={homeHref} class="btn btn-primary">{t(lang, 'notFound.backHome')}</a>
      </div>
    </div>
  </div>
</BaseLayout>
