---
import '../../styles/global.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLang, t } from '../../i18n/utils';
const lang = getLang(Astro.url);
const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.peopleclaw.com';
const blogHref = lang === 'zh' ? '/zh/blog' : '/blog';
const title = t(lang, 'hero.pageTitle');
---
<BaseLayout title={title} description={t(lang, 'hero.description')}>
  <section class="hero bg-base-200 rounded-box p-12 mb-12">
    <div class="hero-content text-center">
      <div class="max-w-2xl">
        <h1 class="text-5xl font-bold">{t(lang, 'hero.title')}</h1>
        <p class="py-6 opacity-80">
          {t(lang, 'hero.description')}
        </p>
        <div class="flex gap-3 justify-center flex-wrap">
          <a href={appUrl} class="btn btn-primary">{t(lang, 'hero.launchApp')}</a>
          <a href={blogHref} class="btn btn-outline">{t(lang, 'hero.readBlog')}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="grid md:grid-cols-3 gap-6">
    <div class="card bg-base-200">
      <div class="card-body">
        <h2 class="card-title">{t(lang, 'features.automate.title')}</h2>
        <p class="opacity-80 text-sm">{t(lang, 'features.automate.body')}</p>
      </div>
    </div>
    <div class="card bg-base-200">
      <div class="card-body">
        <h2 class="card-title">{t(lang, 'features.smallTeams.title')}</h2>
        <p class="opacity-80 text-sm">{t(lang, 'features.smallTeams.body')}</p>
      </div>
    </div>
    <div class="card bg-base-200">
      <div class="card-body">
        <h2 class="card-title">{t(lang, 'features.own.title')}</h2>
        <p class="opacity-80 text-sm">{t(lang, 'features.own.body')}</p>
      </div>
    </div>
  </section>

  <section class="mt-16">
    <h2 class="text-2xl font-bold mb-4">{t(lang, 'latest.title')}</h2>
    <p class="opacity-70 mb-4">{t(lang, 'latest.sub')}</p>
    <a href={blogHref} class="btn btn-outline">{t(lang, 'latest.browseAll')}</a>
  </section>
</BaseLayout>
