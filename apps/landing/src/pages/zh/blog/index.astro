---
import '../../../styles/global.css';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLang, t } from '../../../i18n/utils';
const lang = getLang(Astro.url);
const posts = (await getCollection('blog'))
  .filter(p => (p.data.lang ?? 'en') === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const dateLocale = lang === 'zh' ? 'zh-CN' : 'en-US';
---
<BaseLayout title={t(lang, 'blog.title')} description={t(lang, 'blog.description')}>
  <h1 class="text-4xl font-bold mb-8">{t(lang, 'blog.heading')}</h1>
  <div class="space-y-4">
    {posts.map(post => {
      const slug = post.id.replace(/^zh\//, '');
      return (
      <a href={`/zh/blog/${slug}`} class="card bg-base-200 hover:bg-base-300 transition-colors">
        <div class="card-body">
          <h2 class="card-title">{post.data.title}</h2>
          <p class="opacity-80 text-sm">{post.data.description}</p>
          <div class="flex gap-2 items-center text-xs opacity-60 mt-2">
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString(dateLocale)}</time>
            <div class="flex gap-1 ml-2">
              {post.data.tags.map(tag => <span class="badge badge-outline badge-xs">{tag}</span>)}
            </div>
          </div>
        </div>
      </a>
    )})}
  </div>
</BaseLayout>
