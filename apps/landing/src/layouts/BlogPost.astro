---
import BaseLayout from './BaseLayout.astro';
import { getLang, t } from '../i18n/utils';
export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}
const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;
const lang = getLang(Astro.url);
const dateLocale = lang === 'zh' ? 'zh-CN' : 'en-US';
const blogHref = lang === 'zh' ? '/zh/blog' : '/blog';
---
<BaseLayout title={title} description={description}>
  <article class="prose prose-invert mx-auto max-w-3xl">
    <header class="mb-8 not-prose">
      <h1 class="text-4xl font-bold">{title}</h1>
      <p class="opacity-70 mt-2">{description}</p>
      <div class="flex gap-2 items-center text-sm opacity-60 mt-3">
        <time datetime={pubDate.toISOString()}>{pubDate.toLocaleDateString(dateLocale)}</time>
        {updatedDate && <span>{t(lang, 'blog.updatedOn')} {updatedDate.toLocaleDateString(dateLocale)}</span>}
        {tags.length > 0 && (
          <div class="flex gap-1 ml-2">
            {tags.map(tg => <span class="badge badge-outline badge-sm">{tg}</span>)}
          </div>
        )}
      </div>
    </header>
    <slot />
    <div class="mt-10 not-prose">
      <a href={blogHref} class="btn btn-ghost btn-sm">{t(lang, 'blog.backToList')}</a>
    </div>
  </article>
</BaseLayout>
