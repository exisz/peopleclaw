---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { getLang, t } from '../i18n/utils';
export interface Props {
  title: string;
  description?: string;
}
const lang = getLang(Astro.url);
const { title, description = t(lang, 'footer.tagline') } = Astro.props;
const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.peopleclaw.com';
const blogHref = lang === 'zh' ? '/zh/blog' : '/blog';
const homeHref = lang === 'zh' ? '/zh/' : '/';
---
<!doctype html>
<html lang={lang} data-theme="luxury">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      body { font-family: 'Inter', system-ui, sans-serif; }
    </style>
  </head>
  <body class="min-h-screen bg-base-100 dot-pattern">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-base-100/70 border-b border-base-content/5">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href={homeHref} class="text-xl font-bold tracking-tight text-base-content">
          <span class="text-primary">People</span>Claw
        </a>
        <div class="flex items-center gap-3">
          <LanguageSwitcher />
          <a href={blogHref} class="btn btn-ghost btn-sm text-base-content/70 hover:text-base-content">{t(lang, 'nav.blog')}</a>
          <a href={appUrl} class="btn btn-primary btn-sm">{t(lang, 'nav.launchApp')}</a>
        </div>
      </div>
    </nav>

    <!-- Main content with top padding for fixed nav -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-base-content/5 mt-32">
      <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-4">
        <div>
          <p class="text-base-content/50 text-sm">{t(lang, 'footer.tagline')}</p>
        </div>
        <div class="flex items-center gap-6">
          <a href={blogHref} class="text-sm text-base-content/40 hover:text-primary transition-colors">{t(lang, 'nav.blog')}</a>
          <a href={appUrl} class="text-sm text-base-content/40 hover:text-primary transition-colors">{t(lang, 'nav.launchApp')}</a>
        </div>
        <p class="text-base-content/20 text-[10px] font-mono">
          {import.meta.env.VERCEL_GIT_COMMIT_SHORT_SHA
            ? `${import.meta.env.VERCEL_GIT_COMMIT_SHORT_SHA}`
            : 'dev'}
        </p>
      </div>
    </footer>
  </body>
</html>
