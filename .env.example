# ============================================================
# Landing（apps/landing）—— 只需一个 var
# ============================================================
# 指向 admin app 部署的 URL，首页的 "Launch App" 按钮会跳到这里
PUBLIC_APP_URL=https://app.peopleclaw.rollersoft.com.au

# ============================================================
# Admin（apps/admin）—— SPA + Express + Prisma + Logto
# ============================================================

# --- SPA（Vite，必须 VITE_ 前缀）---
VITE_LOGTO_ENDPOINT=https://id.rollersoft.com.au
VITE_LOGTO_APP_ID=<logto-spa-app-id>
VITE_LOGTO_API_RESOURCE=https://app.peopleclaw.rollersoft.com.au/api

# --- Express / Prisma 运行时 ---
LOGTO_ENDPOINT=https://id.rollersoft.com.au
LOGTO_API_RESOURCE=https://app.peopleclaw.rollersoft.com.au/api

# Turso — Vercel 集成自动注入到 production/preview，本地开发留空走 LOCAL_DATABASE_URL
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# 本地开发用的 SQLite（prisma CLI + dev 运行时）
LOCAL_DATABASE_URL=file:./prisma/dev.db

# ============================================================
# Real handlers (P3) — placeholder for now
# ============================================================
# OpenAI / AI provider for ai_description handler
OPENAI_API_KEY=

# Shopify creds — per-tenant in DB at runtime; this is dev fallback
SHOPIFY_DEV_SHOP=
SHOPIFY_DEV_ADMIN_TOKEN=

# Mocking flags for P4 e2e tests
SHOPIFY_MOCK=false
AI_MOCK=false

# ============================================================
# PLANET-1045: Logto → Resend email bridge
# ============================================================
# Resend API key (create at https://resend.com)
RESEND_API_KEY=re_xxx

# Shared secret between Logto http-email connector and our bridge endpoint.
# Generate: openssl rand -base64 32
LOGTO_EMAIL_WEBHOOK_SECRET=<generate with: openssl rand -base64 32>
