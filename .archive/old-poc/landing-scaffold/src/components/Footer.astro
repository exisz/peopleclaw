---
const year = new Date().getFullYear();
---
<footer class="border-t border-white/10 mt-12">
  <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2 text-sm">
      <span class="text-xl">🐾</span>
      <span class="font-semibold">PeopleClaw</span>
      <span class="text-gray-500">— People-centric workflow automation</span>
    </div>
    <div class="flex items-center gap-6 text-sm text-gray-400">
      <a href="https://github.com/exisz/peopleclaw" class="hover:text-white" target="_blank" rel="noopener">GitHub</a>
      <a href="/docs" class="hover:text-white opacity-60 cursor-not-allowed" aria-disabled="true">Docs (soon)</a>
      <a href="https://peopleclaw.vercel.app/#app" class="hover:text-white">POC</a>
    </div>
    <div class="text-xs text-gray-500">© {year} PeopleClaw</div>
  </div>
</footer>
